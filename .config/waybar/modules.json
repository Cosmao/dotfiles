{
	// workspaces
	"hyprland/workspaces" : {
		"on-click": "activate",
		"active-only": false,
		"all-outputs": true,
		"format": "{}",
		"format-icons": {
			"urgent": "",
			"active": "",
			"default": ""
		},
		"persistent-workspaces": {
			"*": 5
		},
	},
   	
	// taskbar
	"wlr/taskbar": {
		"format": "{icon}",
		"icon-size": 18,
		"tooltip-format": "{title}",
		"on-click": "activate",
		"on-click-middle": "close",
	},
	
	// clock
	"clock": {  
		"interval": 1,
		// "format": "{:%H:%M}",
		"format": "{:%A, %B %d - %H:%M}",
		"tooltip-format": "<big>{calendar}</big>",
		"calendar": {
			"mode": "month",
			"mode-mon-col": 3,
			"weeks-pos": "right",
			"on-scroll": 1,
			"format": {
				"months": "<span color='#ffffff'><b>{}</b></span>",
				"days": "<span color='#ffffff'><b>{}</b></span>",
				"weeks": "<span color='#ffffff'><b>W{}</b></span>",
				"weekdays": "<span color='#ffffff'><b>{}</b></span>",
				"today": "<span color='#ffffff'><b><u>{}</u></b></span>"
			}
		}
	},
	
	// hardware
	"group/hardware": {
		"orientation": "inherit",
		"drawer": {
			"transition-duration": 300,
			"children-class": "not-memory",
			"transition-left-to-right": false
		},        
		"modules": [
			"custom/system",
			"cpu",
			"temperature",
			"disk",
			"memory"
		]
	},
	
	// system
	"custom/system": {
		"format": "<span size='small'> ¾░Æŗ </span>",
		"tooltip": false
	},
	
	// CPU
	"cpu": {
		"format": " ¾░Źø {usage}% ",
		"on-click": "kitty btop"
	},
	
	// temperature
	"temperature": {
		"format": " ¾░łĖ {temperatureC}┬░C ",
		"on-click": "kitty btop"
	},
	
	// harddisc space
	"disk": {
		"interval": 30,
		"format": " ¾░ŗŖ {percentage_used}% ",
		"path": "/home",
		"on-click": "kitty btop"
	}, 
	
	// memory
	"memory": {
		"format": " ¾░å╝ {}% ",
		"on-click": "kitty btop"
	},
	
	// media
	"custom/playerctl": {
		"exec": "playerctl --ignore-player=firefox metadata --format '{{ artist }} - {{ title }}'",
		"exec-if": "playerctl --ignore-player=firefox status 2>/dev/null",
		"interval": 2,
		"max-length": 45
	},

	// audio
	"pulseaudio": {
		"scroll-step": 1,
		"format": "{icon} {volume}%",
		"format-bluetooth": "{volume}% {icon} ’Ŗö {format_source}",
		"format-bluetooth-muted": "¾░¢ü {icon} ’Ŗö {format_source}",
		"format-muted": "¾░¢ü {format_source}",
		"format-source": "{volume}% ’ä░",
		"format-source-muted": "’ä▒",
		"format-icons": {
			"headphone": "’Ćź",
			"phone": "’éĢ",
			"car": "’å╣",
			"default": ["’Ć”", "’Ć©", "’Ć©"]
		},
		"on-click": "pavucontrol"
	},
	
	// bluetooth
	"bluetooth": {
		"format": "’Ŗō {status}",
		"format-disabled": "’Ŗō {status}",
		"format-off": "’Ŗō {status}",
		"interval": 30,
		"on-click": "blueman-manager",
		"format-no-controller": ""
	},
	
	// network
	"network": {
		"format": "{ifname}",
		"format-wifi": "’ć½ {signalStrength}%",
		"format-ethernet": "¾░īś {ifname}",
		"format-disconnected": "disconnected",
		"tooltip-format": "¾░īś {ifname} via {gwaddri}",
		"tooltip-format-wifi": "’ć½ {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\n’ä╣ {bandwidthUpBits} ’ä║ {bandwidthDownBits}",
		"tooltip-format-ethernet": "¾░īś {ifname}\nIP: {ipaddr}\n ’ä╣ {bandwidthUpBits} ’ä║ {bandwidthDownBits}",
		"tooltip-format-disconnected": "disconnected",
		"max-length": 50,
		"on-click": "nm-connection-editor"
		//"on-click": "~/dotfiles/.settings/networkmanager.sh"
	},
	
	// battery
	"battery": {
		"states": {
			"good": 95,
			"warning": 30,
			"critical": 10
		},
		"format": "{icon} {capacity}%",
		"format-charging": "’ć” {capacity}%",
		"format-plugged": "’ć” {capacity}%",
		"format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"]
	},
	
	// power menu
	"custom/exit": {
		"format": "’Ćæ",
		"on-click": "wlogout -b 2",
		"tooltip": false		
	},
}

